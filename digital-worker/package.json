{
  "name": "itsm-operations-digital-worker",
  "version": "1.0.0",
  "main": "dist/index.js",
  "type": "commonjs",
  "description": "Agent 365 Digital Worker - ITSM Operations with incident auto-triage, SLA prediction, shift handover, trend analysis, and voice",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon --watch src --exec ts-node src/index.ts",
    "test-tool": "agentsplayground",
    "build": "tsc && node -e \"const fs=require('fs'),p=require('path');const s=p.join('src','voice','voice.html'),d=p.join('dist','voice');fs.mkdirSync(d,{recursive:true});fs.copyFileSync(s,p.join(d,'voice.html'));console.log('Copied voice.html');const mc=p.join('src','mission-control.html');fs.copyFileSync(mc,p.join('dist','mission-control.html'));console.log('Copied mission-control.html');function copyDir(src,dst){if(!fs.existsSync(src))return;fs.mkdirSync(dst,{recursive:true});for(const e of fs.readdirSync(src,{withFileTypes:true})){const sp=p.join(src,e.name),dp=p.join(dst,e.name);if(e.isDirectory())copyDir(sp,dp);else if(e.name.endsWith('.json'))fs.copyFileSync(sp,dp);}}copyDir(p.join('src','demo','scenarios'),p.join('dist','demo','scenarios'));copyDir(p.join('src','demo','seed-data'),p.join('dist','demo','seed-data'));copyDir(p.join('src','demo','tenant-profiles'),p.join('dist','demo','tenant-profiles'));console.log('Copied demo JSON resources')\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint --config ../eslint.config.mjs src/",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist node_modules package-lock.json",
    "install:clean": "npm run clean && npm install"
  },
  "license": "MIT",
  "dependencies": {
    "@azure-rest/ai-content-safety": "^1.0.1",
    "@azure/communication-call-automation": "^1.5.1",
    "@azure/communication-common": "^2.4.0",
    "@azure/communication-identity": "^1.3.1",
    "@azure/cosmos": "^4.9.3",
    "@azure/data-tables": "^13.3.2",
    "@azure/identity": "^4.13.1",
    "@azure/keyvault-secrets": "^4.11.1",
    "@azure/monitor-opentelemetry-exporter": "^1.0.0-beta.32",
    "@azure/service-bus": "^7.9.5",
    "@microsoft/agents-a365-notifications": "^0.1.0-preview.30",
    "@microsoft/agents-a365-observability": "^0.1.0-preview.30",
    "@microsoft/agents-a365-observability-extensions-openai": "^0.1.0-preview.30",
    "@microsoft/agents-a365-observability-hosting": "^0.1.0-preview.64",
    "@microsoft/agents-a365-runtime": "^0.1.0-preview.30",
    "@microsoft/agents-a365-tooling": "^0.1.0-preview.119",
    "@microsoft/agents-a365-tooling-extensions-openai": "^0.1.0-preview.119",
    "@microsoft/agents-activity": "^1.2.2",
    "@microsoft/agents-hosting": "^1.2.2",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@openai/agents": "^0.1.11",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.73.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.215.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-metrics": "^2.7.0",
    "@opentelemetry/sdk-node": "^0.215.0",
    "@opentelemetry/sdk-trace-node": "^2.7.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@types/ws": "^8.18.1",
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "openai": "^4.77.0",
    "pptxgenjs": "^4.0.1",
    "redis": "^5.12.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@microsoft/m365agentsplayground": "^0.2.18",
    "@playwright/test": "^1.59.1",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.9",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^10.2.1",
    "nodemon": "^3.1.10",
    "rimraf": "^5.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "@openai/agents-core": "$@openai/agents",
    "@openai/agents-openai": "$@openai/agents",
    "openai": "$openai"
  }
}
