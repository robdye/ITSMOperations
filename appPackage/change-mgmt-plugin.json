                  },
                  "ci_sys_id": {
                    "type": "string",
                    "description": "CI sys_id"
                  },
                  "limit": {
                    "type": "number",
                    "description": "Max incidents to return (default 10)"
                  }
                },
                "additionalProperties": false
              },
              "annotations": {
                "readOnlyHint": true
              }
            },
            {
