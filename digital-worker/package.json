{
  "name": "itsm-operations-digital-worker",
  "version": "1.0.0",
  "main": "dist/index.js",
  "type": "commonjs",
  "description": "Agent 365 Digital Worker - ITSM Operations with incident auto-triage, SLA prediction, shift handover, trend analysis, and voice",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon --watch src --exec ts-node src/index.ts",
    "test-tool": "agentsplayground",
    "build": "tsc && node scripts/copy-static.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint --config ../eslint.config.mjs src/",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist node_modules package-lock.json",
    "install:clean": "npm run clean && npm install"
  },
  "license": "MIT",
  "dependencies": {
    "@azure-rest/ai-content-safety": "^1.0.1",
    "@azure/communication-call-automation": "1.5.1",
    "@azure/communication-common": "2.4.0",
    "@azure/communication-identity": "1.3.1",
    "@azure/cosmos": "^4.9.3",
    "@azure/data-tables": "^13.3.2",
    "@azure/identity": "^4.13.1",
    "@azure/keyvault-secrets": "^4.11.1",
    "@azure/monitor-opentelemetry-exporter": "^1.0.0-beta.32",
    "@azure/service-bus": "^7.9.5",
    "@microsoft/agents-a365-notifications": "0.1.0-preview.64",
    "@microsoft/agents-a365-observability": "0.1.0-preview.64",
    "@microsoft/agents-a365-observability-extensions-openai": "0.1.0-preview.64",
    "@microsoft/agents-a365-observability-hosting": "0.1.0-preview.64",
    "@microsoft/agents-a365-runtime": "0.1.0-preview.64",
    "@microsoft/agents-a365-tooling": "0.1.0-preview.119",
    "@microsoft/agents-a365-tooling-extensions-openai": "0.1.0-preview.119",
    "@microsoft/agents-activity": "1.5.1",
    "@microsoft/agents-hosting": "1.5.1",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@openai/agents": "^0.1.11",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.73.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.215.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-metrics": "^2.7.0",
    "@opentelemetry/sdk-node": "^0.215.0",
    "@opentelemetry/sdk-trace-node": "^2.7.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@types/ws": "^8.18.1",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "openai": "^4.77.0",
    "pptxgenjs": "^4.0.1",
    "redis": "^5.12.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@microsoft/m365agentsplayground": "^0.2.18",
    "@playwright/test": "^1.59.1",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.9",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^10.2.1",
    "nodemon": "^3.1.10",
    "rimraf": "^5.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "@openai/agents-core": "$@openai/agents",
    "@openai/agents-openai": "$@openai/agents",
    "openai": "$openai"
  }
}
