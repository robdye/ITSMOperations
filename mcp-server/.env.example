# Environment variables for Change Management MCP Server
# ServiceNow OAuth credentials
SNOW_INSTANCE=https://YOUR_INSTANCE.service-now.com
SNOW_CLIENT_ID=YOUR_CLIENT_ID
SNOW_CLIENT_SECRET=YOUR_CLIENT_SECRET
SNOW_USER=YOUR_USERNAME
SNOW_PASSWORD=YOUR_PASSWORD

# Server configuration
PORT=3002
SERVER_BASE_URL=http://localhost:3002
