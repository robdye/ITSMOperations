{
  "$schema": "https://developer.microsoft.com/json-schemas/copilot/plugin/v2.4/schema.json",
  "schema_version": "v2.4",
  "name_for_human": "ITSM Monitoring",
  "description_for_human": "Infrastructure monitoring: Azure alerts and resource health status.",
  "namespace": "itsm-monitoring",
  "functions": [
    {
      "name": "get-azure-alerts",
      "description": "Get Azure Monitor alerts for infrastructure health."
    }
  ],
  "runtimes": [
    {
      "type": "RemoteMCPServer",
      "run_for_functions": [
        "get-azure-alerts"
      ],
      "spec": {
        "url": "${{CHANGE_MCP_ENDPOINT}}",
        "x-mcp_tool_description": {
          "tools": [
            {
              "name": "get-azure-alerts",
              "description": "Get Azure Monitor alerts for infrastructure health.",
              "inputSchema": {
                "type": "object",
                "properties": {
                  "limit": {
                    "type": "number",
                    "description": "Max results"
                  }
                },
                "additionalProperties": false
              },
              "annotations": {
                "readOnlyHint": true
              }
            }
          ]
        }
      },
      "auth": {
        "type": "None"
      }
    }
  ]
}