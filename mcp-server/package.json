{
  "name": "change-mgmt-mcp",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "Change Management MCP Server — ServiceNow CMDB, EOL lifecycle, blast radius, and risk dashboards for M365 Copilot",
  "scripts": {
    "build:widgets": "node widgets/build.mjs",
    "start": "node --env-file=.env --import tsx src/index.ts",
    "dev": "node --env-file=.env --import tsx --watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint --config ../eslint.config.mjs src/",
    "typecheck": "tsc --noEmit",
    "inspector": "npx @modelcontextprotocol/inspector"
  },
  "dependencies": {
    "@azure/search-documents": "^13.0.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.64.0",
    "@vitest/coverage-v8": "^4.1.5",
    "esbuild": "^0.25.0",
    "eslint": "^10.3.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
