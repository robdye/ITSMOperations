# Environment config for Teams Toolkit
APP_NAME_SUFFIX=dev
TEAMSFX_ENV=dev
CHANGE_MCP_ENDPOINT=http://127.0.0.1:3002/mcp
MCP_VALID_DOMAIN=127.0.0.1
# Placeholder — real value lives in Key Vault (kv-itsm-ops/mcp-api-key) and is
# injected into Container Apps as a secret reference. Override locally only if
# you're hitting a privately-keyed MCP endpoint outside Azure.
MCP_API_KEY=<set-in-key-vault>
CONTAINER_APP_URL=http://127.0.0.1:3978
AZURE_SEARCH_ENDPOINT=
SERVICENOW_OAUTH_REGISTRATION_ID=
