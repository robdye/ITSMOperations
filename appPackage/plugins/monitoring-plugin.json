{
  "$schema": "https://developer.microsoft.com/json-schemas/copilot/plugin/v2.4/schema.json",
  "schema_version": "v2.4",
  "name_for_human": "ITSM Monitoring",
  "description_for_human": "Infrastructure monitoring: Azure alerts and resource health status.",
  "namespace": "itsm-monitoring",
  "functions": [
    {
      "name": "get-azure-alerts",
      "description": "Get Azure Monitor alerts for infrastructure health."
    },
    {
      "name": "get-resource-health",
      "description": "Get Azure resource health status for monitored infrastructure components."
    }
  ],
  "runtimes": [
    {
      "type": "RemoteMCPServer",
      "run_for_functions": [
        "get-azure-alerts",
        "get-resource-health"
      ],
      "spec": {
        "url": "${{CHANGE_MCP_ENDPOINT}}",
        "mcp_tool_description": {
          "tools": [
            {
              "name": "get-azure-alerts",
              "description": "Get Azure Monitor alerts for infrastructure health.",
              "inputSchema": {
                "type": "object",
                "properties": {
                  "limit": {
                    "type": "number",
                    "description": "Max results"
                  }
                },
                "additionalProperties": false
              },
              "annotations": {
                "readOnlyHint": true
              }
            },
            {
              "name": "get-resource-health",
              "description": "Get Azure resource health status for monitored infrastructure components.",
              "inputSchema": {
                "type": "object",
                "properties": {
                  "resource_name": {
                    "type": "string",
                    "description": "Name of the Azure resource to check"
                  },
                  "resource_type": {
                    "type": "string",
                    "description": "Azure resource type (e.g. Microsoft.Compute/virtualMachines)"
                  }
                },
                "additionalProperties": false
              },
              "annotations": {
                "readOnlyHint": true
              }
            }
          ]
        }
      }
    }
  ]
}