                "show-change-dashboard",
                "show-change-request",
                "show-change-briefing",
                "show-change-metrics",
                "get-change-requests",
                "prepare-change-request",
                "create-change-request",
                "update-change-request",
                "detect-change-collisions",
                "generate-cab-agenda",
                "get-change-history",
