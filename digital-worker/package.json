{
  "name": "itsm-operations-digital-worker",
  "version": "1.0.0",
  "main": "dist/index.js",
  "type": "commonjs",
  "description": "Agent 365 Digital Worker - ITSM Operations with incident auto-triage, SLA prediction, shift handover, trend analysis, and voice",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon --watch src --exec ts-node src/index.ts",
    "test-tool": "agentsplayground",
    "build": "tsc && node -e \"const fs=require('fs'),p=require('path');const s=p.join('src','voice','voice.html'),d=p.join('dist','voice');fs.mkdirSync(d,{recursive:true});fs.copyFileSync(s,p.join(d,'voice.html'));console.log('Copied voice.html')\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint --config ../eslint.config.mjs src/",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist node_modules package-lock.json",
    "install:clean": "npm run clean && npm install"
  },
  "license": "MIT",
  "dependencies": {
    "@azure/data-tables": "^13.3.2",
    "@azure/identity": "^4.13.1",
    "@microsoft/agents-a365-notifications": "^0.1.0-preview.30",
    "@microsoft/agents-a365-observability": "^0.1.0-preview.30",
    "@microsoft/agents-a365-observability-extensions-openai": "^0.1.0-preview.30",
    "@microsoft/agents-a365-observability-hosting": "^0.1.0-preview.64",
    "@microsoft/agents-a365-runtime": "^0.1.0-preview.30",
    "@microsoft/agents-a365-tooling": "^0.1.0-preview.119",
    "@microsoft/agents-a365-tooling-extensions-openai": "^0.1.0-preview.119",
    "@microsoft/agents-activity": "^1.2.2",
    "@microsoft/agents-hosting": "^1.2.2",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@openai/agents": "^0.1.11",
    "@types/ws": "^8.18.1",
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "node-cron": "^3.0.3",
    "openai": "^4.77.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@microsoft/m365agentsplayground": "^0.2.18",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.9",
    "@types/node-cron": "^3.0.11",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^10.2.1",
    "nodemon": "^3.1.10",
    "rimraf": "^5.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "@openai/agents-core": "$@openai/agents",
    "@openai/agents-openai": "$@openai/agents",
    "openai": "$openai"
  }
}
