{
    "$schema": "https://developer.microsoft.com/json-schemas/copilot/plugin/v2.4/schema.json",
    "schema_version": "v2.4",
    "name_for_human": "ITSM Operations",
    "description_for_human": "ServiceNow ITSM tools — incidents, changes, problems, SLAs, CMDB assets, knowledge, and monitoring with interactive widget dashboards.",
    "namespace": "itsmops",
    "functions": [
        { "name": "show-itsm-briefing", "description": "Display the ITSM Operations Briefing — a holistic view across incidents, problems, SLAs, changes, and assets." },
        { "name": "show-incident-dashboard", "description": "Display the Incident Dashboard with all active incidents by priority, with clickable ServiceNow links." },
        { "name": "get-incidents", "description": "Query ServiceNow incidents by state, priority, category, or assignment group." },
        { "name": "create-incident", "description": "Create a new incident in ServiceNow." },
        { "name": "update-incident", "description": "Update an existing incident in ServiceNow." },
        { "name": "get-incidents-for-ci", "description": "Get active incidents for a Configuration Item to assess impact on planned changes." },
        { "name": "show-change-dashboard", "description": "Display the Change Management dashboard with open change requests, risk heat map, and ITIL classification breakdown." },
        { "name": "show-change-request", "description": "Display a detailed Change Request with CI details, risk assessment, approval chain, and backout plan." },
        { "name": "show-change-briefing", "description": "Display the Change Risk Briefing — change collisions, stale CRs, high-risk changes, and recommendations." },
        { "name": "show-change-metrics", "description": "Display Change Management KPIs — success rate, emergency change percentage, and pipeline breakdown." },
        { "name": "get-change-requests", "description": "Query ServiceNow for change requests. Returns structured data for analysis." },
        { "name": "prepare-change-request", "description": "Open an interactive form to create a new ServiceNow Change Request. Pre-fills from conversation context." },
        { "name": "create-change-request", "description": "Create a new Change Request in ServiceNow." },
        { "name": "update-change-request", "description": "Update an existing Change Request in ServiceNow by number or sys_id." },
        { "name": "detect-change-collisions", "description": "Detect open changes targeting the same Configuration Item." },
        { "name": "generate-cab-agenda", "description": "Generate a CAB meeting agenda with pending changes, risk scores, and recommendations." },
        { "name": "get-change-history", "description": "Find similar past changes with success/failure rates and lessons learned." },
        { "name": "post-implementation-review", "description": "Check if a completed change caused incidents within 48 hours." },
        { "name": "show-problem-dashboard", "description": "Display the Problem Dashboard with open problems and known errors." },
        { "name": "create-problem", "description": "Create a problem record from recurring incidents." },
        { "name": "get-problem", "description": "Get details of a specific problem record by number or sys_id." },
        { "name": "show-sla-dashboard", "description": "Display the SLA Compliance Dashboard showing breaches, at-risk SLAs, and compliance rate." },
        { "name": "get-sla-breaches", "description": "Get a list of current SLA breaches with affected services and breach details." },
        { "name": "get-cmdb-ci", "description": "Get a Configuration Item from CMDB with full details including class, status, environment, and owner." },
        { "name": "get-ci-relationships", "description": "Get upstream and downstream CI relationships from the CMDB relationship table." },
        { "name": "update-cmdb-ci", "description": "Update a Configuration Item in the ServiceNow CMDB." },
        { "name": "get-assets", "description": "Query IT assets including hardware, software, and warranty status." },
        { "name": "get-expired-warranties", "description": "Get assets with expired warranties." },
        { "name": "get-catalog-items", "description": "List available Service Catalog items." },
        { "name": "show-asset-lifecycle", "description": "Display the Asset Lifecycle compliance dashboard with EOL status, risk scores, and remediation actions." },
        { "name": "show-blast-radius", "description": "Display the Blast Radius dependency graph showing how a CI failure cascades to connected services." },
        { "name": "show-risk-forecast", "description": "Display the EOL Risk Forecast timeline showing assets approaching end of life with projected risk scores." },
        { "name": "search-knowledge", "description": "Search the ServiceNow Knowledge Base for articles, runbooks, and procedures." },
        { "name": "harvest-knowledge", "description": "Harvest knowledge from resolved incidents to identify candidates for new KB articles." },
        { "name": "create-kb-article", "description": "Create a new Knowledge Base article in ServiceNow." },
        { "name": "get-azure-alerts", "description": "Get Azure Monitor alerts for infrastructure health." },
        { "name": "get-resource-health", "description": "Get Azure resource health status for monitored infrastructure components." }
    ],
    "runtimes": [
        {
            "type": "RemoteMCPServer",
